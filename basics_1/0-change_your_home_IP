#!/usr/bin/env bash
# Configure /etc/hosts sans utiliser sed -i pour éviter le bug "Device or resource busy"

# Étape 1 : On modifie localhost en remplaçant 127.0.0.1 par 127.0.0.2 via un flux de texte
hosts_content=$(sed 's/127.0.0.1\tlocalhost/127.0.0.2\tlocalhost/g' /etc/hosts | sed 's/127.0.0.1 localhost/127.0.0.2 localhost/g')

# Étape 2 : On gère facebook.com dans le flux de texte
if echo "$hosts_content" | grep -q "facebook.com"; then
    hosts_content=$(echo "$hosts_content" | sed 's/.*facebook.com/8.8.8.8 facebook.com/g')
else
    hosts_content=$(echo -e "${hosts_content}\n8.8.8.8\tfacebook.com")
fi

# Étape 3 : On écrase proprement le fichier /etc/hosts avec le nouveau contenu
echo "$hosts_content" > /etc/hosts
