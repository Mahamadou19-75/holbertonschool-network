#!/usr/bin/env bash
# Configure /etc/hosts sans sed -i et sans avertissement ShellCheck

# Étape 1 : Lire /etc/hosts et remplacer localhost (127.0.0.1) par 127.0.0.2
# On filtre également pour ignorer l'ancienne ligne facebook.com si elle existe
hosts_content=$(sed -e 's/127.0.0.1\tlocalhost/127.0.0.2\tlocalhost/g' \
                    -e 's/127.0.0.1 localhost/127.0.0.2 localhost/g' /etc/hosts | grep -v "facebook.com")

# Étape 2 : Écrire le nouveau contenu et ajouter la ligne facebook.com à la fin
echo "$hosts_content" > /etc/hosts
echo -e "8.8.8.8\tfacebook.com" >> /etc/hosts
